{
  "name": "lan-file-share",
  "version": "0.1.0",
  "private": true,
  "description": "LAN file sharing between PC (Electron) and phone (PWA). Register with a device name, browse, upload, download, preview, search, delete, rename, mkdir, and generate share links over your local network.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "dev": "LAN_FILE_SHARE_DEV=1 electron .",
    "lint": "eslint \"**/*.js\" --ignore-path .gitignore",
    "postinstall": "node scripts/generate-icons.js || true"
  },
  "author": "faizinuha",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "qrcode": "^1.5.3",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "electron": "^30.0.9",
    "eslint": "^8.57.0"
  }
}
