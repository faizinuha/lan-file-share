{
  "name": "lan-file-share",
  "version": "0.5.0",
  "private": true,
  "description": "LAN file sharing between PC (Electron) and phone (PWA). Register with a device name, browse, upload, download, preview, search, delete, rename, mkdir, WebDAV mount, and generate share links over your local network.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "dev": "LAN_FILE_SHARE_DEV=1 electron .",
    "lint": "eslint \"**/*.js\" --ignore-path .gitignore",
    "smoke-test": "node scripts/smoke-test.js",
    "postinstall": "node scripts/generate-icons.js || true",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "author": {
    "name": "faizinuha",
    "email": "rozakadm@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/faizinuha/lan-file-share",
  "repository": {
    "type": "git",
    "url": "https://github.com/faizinuha/lan-file-share.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.19.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "qrcode": "^1.5.3",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0"
  },
  "build": {
    "appId": "com.faizinuha.lanfileshare",
    "productName": "LAN File Share",
    "copyright": "Copyright © 2026 faizinuha",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "webdav.js",
      "upload-chunks.js",
      "public/**/*",
      "scripts/generate-icons.js",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "LAN File Share ${version}",
      "icon": "build/icon.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200,
          "type": "file"
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LAN File Share",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network;FileTransfer;Utility",
      "icon": "build/icon.png",
      "synopsis": "Share files between PC and phone over LAN",
      "desktop": {
        "Name": "LAN File Share",
        "Comment": "Share files between PC and phone on the same WiFi",
        "Keywords": "share;lan;file;wifi;webdav;pwa;"
      }
    },
    "publish": [
      {
        "provider": "github",
        "owner": "faizinuha",
        "repo": "lan-file-share",
        "releaseType": "release"
      }
    ]
  }
}
